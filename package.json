{
  "name": "@teamvortexsoftware/vortex-node-22-sdk",
  "description": "Vortex Node 22 SDK",
  "author": "@teamvortexsoftware",
  "version": "0.20.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prepack": "echo 'This package should not be published. Use publish:stg or publish:prod' && exit 1",
    "build:stg": "pnpm run distclean && pnpm run build && mkdir -p dist.d/stg && mv dist dist.d/stg && echo && echo 'Build in ./dist.d/stg'",
    "prepublish:stg": "cp ./LICENSE ./README.md ./dist.d/stg/ && jq '.name = \"@teamvortexsoftware/vortex-node-22-sdk-stg\" | .description = \"Vortex Node 22 SDK (STG)\" | del(.devDependencies.\"@teamvortexsoftware/eslint-config\") | del(.devDependencies.\"@teamvortexsoftware/typescript-config\") | del(.scripts.prepack)' ./package.json > ./dist.d/stg/package.json",
    "publish:stg": "pnpm run prepublish:stg && pnpm publish --access restricted ./dist.d/stg",
    "build:prod": "pnpm run distclean && pnpm run build && mkdir -p dist.d/prod && mv dist dist.d/prod && echo && echo 'Build in ./dist.d/prod'",
    "prepublish:prod": "cp ./LICENSE ./README.md ./dist.d/prod/ && jq 'del(.devDependencies.\"@teamvortexsoftware/eslint-config\") | del(.devDependencies.\"@teamvortexsoftware/typescript-config\") | del(.scripts.prepack)' ./package.json > ./dist.d/prod/package.json",
    "publish:prod": "pnpm run prepublish:prod && pnpm publish --access public ./dist.d/prod",
    "check-types": "tsgo --noEmit",
    "distclean": "rm -rf ./dist ./dist.d",
    "clean": "rm -rf ./dist",
    "dev": "tsc -p tsconfig.dts.json && tsup --watch",
    "test": "jest",
    "package": "pnpm run build && cd dist/vortex-node-22-sdk && npm pack",
    "build": "tsup && tsc -p tsconfig.dts.json",
    "extract:manifest": "ts-node --esm bin/extract-manifest.ts --out manifest.json",
    "validate:manifest": "pnpm run extract:manifest && node ../../docs/schemas/validate-manifest.js manifest.json && rm manifest.json",
    "generate:readme": "pnpm run extract:manifest && node ../../docs/generators/generate-readme.js manifest.json --out README.md && rm manifest.json"
  },
  "jest": {
    "rootDir": "__tests__",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/../tsconfig.json",
          "compilerOptions": {
            "moduleResolution": "bundler"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@jest/globals": "29.7.0",
    "@teamvortexsoftware/eslint-config": "workspace:*",
    "@teamvortexsoftware/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "29.7.0",
    "ts-jest": "catalog:",
    "ts-morph": "27.0.2",
    "ts-node": "10.9.2",
    "tsup": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "dependencies": {
    "uuid": "catalog:"
  }
}
